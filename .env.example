# ⚠️ BU DOSYA ÖRNEKTİR. GERÇEK DEĞERLERİ ASLA BURAYA YAZMA!
# Gerçek .env dosyası .gitignore ile korunur.
# Bu dosyayı kopyalayıp .env olarak kullan.

TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=
INVEKTO_DEPARTMENT_NAME=Gelen Arama,MESAI DIŞI
POLLING_INTERVAL_SECONDS=30
NOTIFY_UNCOMPLETED_ONLY=true
# Departman adında substring eşleştirme (varsayılan: false = tam eşleşme)
INVEKTO_DEPARTMENT_LOOSE_MATCH=false
BOT_TIMEZONE=Europe/Istanbul
DAILY_REPORT_HOUR=10
# /iletilenkacancagri kayitlarini saklama suresi (gun)
DELIVERED_RETENTION_DAYS=30

# Deploy sonrası tek seferlik backfill (yalnızca BACKFILL_DATES doluysa çalışır)
BACKFILL_ON_STARTUP=true
BACKFILL_DATES=27.06.2026
BACKFILL_AFTER_TIME=14:57:00
# BACKFILL_THROTTLE_SECONDS=0.15

# Railway volume desteği için (UI'dan Volume ekledikten sonra):
# DATA_DIR=/app/data